<section class="mb-6 border rounded-md bg-white border-slate-200 overflow-hidden">
	<h3 class="text-slate-500 text-lg font-semibold p-3 m-0">
		<i class="fas fa-chart-simple pr-2 text-slate-400" aria-hidden="true"></i>
		Compteurs en base
	</h3>
	<div class="overflow-x-auto">
		<table class="w-full min-w-[880px] text-sm border-collapse">
			<thead>
				<tr class="font-semibold tracking-wide uppercase text-xs bg-slate-50 text-slate-600">
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Cave</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Exploitants</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Prestataires</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Parcelles</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Productions</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Prélèvements</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Events</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Convocations</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Apports</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Notifications</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">Email</th>
					<th scope="col" class="p-3 border border-slate-200 whitespace-nowrap">SMS</th>
				</tr>
			</thead>
			<tbody>
				<tr class="text-center hover:bg-slate-50/60 transition-colors text-slate-900 ">
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ cave.name }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.exploitants }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.prestataires }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.parcelles }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.productions }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.prelevements }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.events }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.convocations }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.apports }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.notifications }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.emailMessages }}</td>
					<td class="p-2 border border-slate-100 tabular-nums font-medium">{{ counters.smsMessages }}</td>
				</tr>
			</tbody>
		</table>
	</div>
</section>

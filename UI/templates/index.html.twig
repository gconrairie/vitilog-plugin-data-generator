{% extends '@DataGenerator/layout_plugin.html.twig' %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('plugins/datagenerator/index.js') }}"></script>
{% endblock %}

{% block page_title %}
	Générateur de données
{% endblock %}

{% block page_description %}
	Générez des données de test pour votre application.
{% endblock %}

{% block page_help %}
	{% include '@DataGenerator/help/index.html.twig' %}
{% endblock %}

{% block page_action %}
	<a href="{{ path('data_generator_ticket_generator') }}" class="btn btn-secondary small" data-turbo="false">
		<i class="fas fa-ticket"></i>
		Générer les tickets d'apports</a>
	<button type="button" class="btn btn-danger" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-all" data-modal-title="Supprimer les données générées ?" data-modal-body="Cette action supprimera toutes les données générées. Êtes-vous sûr de vouloir continuer ? Cette action est irréversible." data-modal-confirm-label="Effacer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
		<i class="fas fa-triangle-exclamation"></i>
		Effacer les données générées</button>

{% endblock %}

{% block main %}
	{% include "@DataGenerator/components/db_snapshot.html.twig" with { counters: counters } %}

	<div class="generator-form">
		{{ form_start(generator_form, { attr: { 'data-turbo': 'false' } }) }}

		<div class="dg-form-grid">
			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-user pr-1"></i>
					Exploitant
				</h3>
				<div class="dg-card_body">
					{{form_row(generator_form.exploitant)}}
					{{form_row(generator_form.email)}}
					{{form_row(generator_form.isPrestataire)}}
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-user pr-1"></i>
					Prestataire
				</h3>

				<div class="dg-card_body">
					{{form_row(generator_form.prestataire)}}
					{{form_row(generator_form.emailPrestataire)}}
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-seedling pr-1"></i>
					Parcelles
				</h3>

				<div class="dg-card_body">
					{{form_row(generator_form.parcelles)}}
					{{form_row(generator_form.cepages)}}
				</div>

				<div class="dg-card_footer">
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-parcelles" data-modal-title="Supprimer les parcelles ?" data-modal-body="Cette action supprimera les parcelles générées. La suppression des parcelles entraîne aussi la suppression des productions rattachées, de leurs prélèvements, convocations, inscriptions, demandes de changement d'horaire et apports. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer les parcelles
					</button>
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-tractor"></i>
					Production</h3>


				<div class="dg-card_body">
					{{form_row(generator_form.production)}}
					{{form_row(generator_form.prelevement)}}
				</div>

				<div class="dg-card_footer">
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-productions" data-modal-title="Supprimer les productions ?" data-modal-body="Cette action supprimera les productions générées. Elle supprimera aussi les convocations, inscriptions, prélèvements, demandes de changement d'horaire, demandes de clôture et apports liés à ces productions. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer production</button>
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-prelevements" data-modal-title="Supprimer les prélèvements ?" data-modal-body="Cette action supprimera uniquement les prélèvements générés rattachés aux productions de la cave. Les productions, convocations et inscriptions restent en place. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer prélèvements</button>
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-comment"></i>
					Convocation</h3>

				<div class="dg-card_body">
					{{form_row(generator_form.convocation)}}
					{{form_row(generator_form.accept)}}

					{{form_row(generator_form.date)}}
				</div>

				<div class="dg-card_footer">
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-convocations" data-modal-title="Supprimer les convocations ?" data-modal-body="Cette action supprimera les convocations générées, les demandes de changement d'horaire et les apports liés. Les inscriptions rattachées seront détachées des convocations supprimées. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer les convocations</button>
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-clipboard-list"></i>
					Inscription</h3>

				<div class="dg-card_body">
					{{form_row(generator_form.inscription)}}
					{{form_row(generator_form.inscriptionRequest)}}
					{{form_row(generator_form.acceptInscription)}}
				</div>

				<div class="dg-card_footer">
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-inscriptions" data-modal-title="Supprimer les inscriptions ?" data-modal-body="Cette action supprimera les inscriptions générées et les demandes de changement d'horaire liées. Les autres données restent en place. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer les inscriptions</button>
				</div>
			</section>

			<section class="dg-card">
				<h3 class="dg-card_title">
					<i class="fas fa-gear"></i>
					Options</h3>

				<div class="dg-card_body">
					{{form_row(generator_form.events)}}
					{{form_row(generator_form.passed)}}
				</div>

				<div class="dg-card_footer">
					<button type="button" data-action="click->modal#openFromEvent" data-modal-form-id="delete-data-generator-events" data-modal-title="Supprimer les events ?" data-modal-body="Cette action supprimera les events générés. Les inscriptions rattachées à ces events, ainsi que leurs demandes de changement d'horaire, seront supprimées avant les events. Cette action est irréversible." data-modal-confirm-label="Supprimer" data-modal-confirm-class="bg-red-600 hover:bg-red-700 focus:ring-red-500">
						<i class="fas fa-triangle-exclamation"></i>
						Supprimer les events</button>
				</div>
			</section>
		</div>

		<button class="btn btn-primary mt-3">
			<i class="fas fa-wand-magic-sparkles"></i>
			Générer les données</button>

		{{form_end(generator_form)}}


	</div>

	{% for target, label in clear_targets %}
		<form id="delete-data-generator-{{ target }}" action="{{ path('data_generator_clear', { target: target }) }}" method="POST" style="display: none;"></form>
	{% endfor %}

{% endblock %}
